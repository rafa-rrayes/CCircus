            {
              "name": "A",
              "width": "N"
            },
            {
              "name": "Sh",
              "width": 3
            }
          ],
          "outputs": [
            {
              "name": "O",
              "width": "N"
            }
          ]
        },
        {
          "name": "ArithShiftR",
          "summary": "Arithmetic (sign-extending) right shift.",
